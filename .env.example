REALDOOR_PACK_PATH=../RealDoor_Hackathon_Starter_Pack_v1/realdoor-hackathon-starter-pack
REALDOOR_SESSION_DIR=backend/.sessions
REALDOOR_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional. Deterministic extraction and Tesseract work without this key.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.6-luna
# Enable only after confirming provider terms, retention controls, and event policy.
REALDOOR_ENABLE_HOSTED_VISION=false
